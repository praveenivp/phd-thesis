  abstract = {Deuterium metabolic imaging (DMI) is a novel MR-based method to spatially map metabolism of deuterated substrates such as [6,6'-2 H2 ]-glucose in vivo. Compared with traditional 13 C-MR-based metabolic studies, the MR sensitivity of DMI is high due to the larger 2 H magnetic moment and favorable T1 and T2 relaxation times. Here, the magnetic field dependence of DMI sensitivity and transmit efficiency is studied on phantoms and rat brain postmortem at 4, 9.4 and 11.7 T. The sensitivity and spectral resolution on human brain in vivo are investigated at 4 and 7 T before and after an oral dose of [6,6'-2 H2 ]-glucose. For small animal surface coils (Ø 30 mm), the experimentally measured sensitivity and transmit efficiency scale with the magnetic field to a power of +1.75 and -0.30, respectively. These are in excellent agreement with theoretical predictions made from the principle of reciprocity for a coil noise-dominant regime. For larger human surface coils (Ø 80 mm), the sensitivity scales as a +1.65 power. The spectral resolution increases linearly due to near-constant linewidths. With optimal multireceiver arrays the acquisition of DMI at a nominal 1 mL spatial resolution is feasible at 7 T.},
  langid = {english},
  pmcid = {PMC7141779},
  keywords = {Animals,Brain,Carbon-13 Magnetic Resonance Spectroscopy,Deuterium,deuterium metabolic imaging,Humans,magnetic field dependence,Magnetic Fields,Magnetic Resonance Imaging,Phantoms Imaging,Rats,resolution,sensitivity,Signal-To-Noise Ratio},
  file = {C:\Users\pvalsala\Zotero\storage\EWXFAYB8\de Graaf et al. - 2020 - On the magnetic field dependence of deuterium metabolic imaging.pdf}
}

@article{delattreSpiralDemystified2010,
  title = {Spiral Demystified},
  author = {Delattre, Bénédicte M.A. and Heidemann, Robin M. and Crowe, Lindsey A. and Vallée, Jean Paul and Hyacinthe, Jean Noël},
  date = {2010},
  journaltitle = {Magnetic Resonance Imaging},
  volume = {28},
  number = {6},
  pages = {862--881},
  publisher = {Elsevier Inc.},
  issn = {0730725X},
  doi = {10.1016/j.mri.2010.03.036},
  url = {http://dx.doi.org/10.1016/j.mri.2010.03.036},
  abstract = {Spiral acquisition schemes offer unique advantages such as flow compensation, efficient k-space sampling and robustness against motion that make this option a viable choice among other non-Cartesian sampling schemes. For this reason, the main applications of spiral imaging lie in dynamic magnetic resonance imaging such as cardiac imaging and functional brain imaging. However, these advantages are counterbalanced by practical difficulties that render spiral imaging quite challenging. Firstly, the design of gradient waveforms and its hardware requires specific attention. Secondly, the reconstruction of such data is no longer straightforward because k-space samples are no longer aligned on a Cartesian grid. Thirdly, to take advantage of parallel imaging techniques, the common generalized autocalibrating partially parallel acquisitions (GRAPPA) or sensitivity encoding (SENSE) algorithms need to be extended. Finally, and most notably, spiral images are prone to particular artifacts such as blurring due to gradient deviations and off-resonance effects caused by B0 inhomogeneity and concomitant gradient fields. In this article, various difficulties that spiral imaging brings along, and the solutions, which have been developed and proposed in literature, will be reviewed in detail. © 2010 Elsevier Inc.},
  keywords = {Blurring,Gradient,Non-cartesian,Off-resonance,Parallel imaging,Spiral},
  file = {C:\Users\pvalsala\Zotero\storage\PF5PG72N\Delattre et al._2010_Spiral demystified.pdf}
}

