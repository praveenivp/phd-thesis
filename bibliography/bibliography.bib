@article{hanMultiphotonMagneticResonance2020,
  title = {Multiphoton Magnetic Resonance in Imaging: {{A}} Classical Description and Implementation},
  shorttitle = {Multiphoton Magnetic Resonance in Imaging},
  author = {Han, Victor and Liu, Chunlei},
  date = {2020},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {84},
