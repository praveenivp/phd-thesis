@article{zaitsevPointSpreadFunction2004,
  title = {Point Spread Function Mapping with Parallel Imaging Techniques and High Acceleration Factors: {{Fast}}, Robust, and Flexible Method for Echo-Planar Imaging Distortion Correction},
