@article{pruessmannSENSESensitivityEncoding1999,
  title = {{{SENSE}}: {{Sensitivity}} Encoding for Fast {{MRI}}},
  author = {Pruessmann, Klaas P. and Weiger, Markus and Scheidegger, Markus B. and Boesiger, Peter},
