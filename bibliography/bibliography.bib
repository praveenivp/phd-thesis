  author = {Serés Roig, Eulalia and De Feyter, Henk M. and Nixon, Terence W. and Ruhm, Loreen and Nikulin, Anton V. and Scheffler, Klaus and Avdievich, Nikolai I. and Henning, Anke and family=Graaf, given=Robin A., prefix=de, useprefix=true},
  date = {2023},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {89},
