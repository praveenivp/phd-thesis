@article{huangSelfcalibrationMethodRadial2007,
  title = {Self-Calibration Method for Radial {{GRAPPA}}/k-t {{GRAPPA}}},
  author = {Huang, Feng and Vijayakumar, Sathya and Li, Yu and Hertel, Sarah and Reza, Shahed and Duensing, George R.},
  date = {2007},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {57},
