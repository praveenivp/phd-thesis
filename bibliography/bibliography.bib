@book{oggWETT1B1Insensitive1994,
  title = {{{WET}}, a {{T1-}} and {{B1-Insensitive Water-Suppression Method}} for in {{Vivo Localized1H NMR Spectroscopy}}},
  author = {Ogg, Robert J. and Kingsley, Peter B. and Taylor, June S.},
  date = {1994},
