  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/%28SICI%291522-2594%28199904%2941%3A4%3C824%3A%3AAID-MRM23%3E3.0.CO%3B2-1},
  urldate = {2023-04-11},
  abstract = {A simple theoretical model was developed to compare the sensitivities (i.e., signal-to-noise ratios per unit imaging time) of two-dimensional (2D) multislice and 3D imaging sequences. The model shows that the sensitivities of 3D and 2D multislice MRI sequences are usually similar. Sensitivities are identical in T2-weighted sequences when the TRs of the two sequences are the same. In T1-weighted gradient-echo sequences, sensitivities are very similar when Ernst angle excitation is used and the TR of the 2D sequence is less than T1. The predictions of the model are confirmed in phantom and animal experiments. Magn Reson Med 41:824–828, 1999. © 1999 Wiley-Liss, Inc.},
  langid = {english},
