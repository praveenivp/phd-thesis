@article{qinPointSpreadFunctions2012,
  title = {Point Spread Functions of the {{T2}} Decay in K-Space Trajectories with Long Echo Train},
  author = {Qin, Qin},
  date = {2012-10-01},
  journaltitle = {Magnetic Resonance Imaging},
  shortjournal = {Magnetic Resonance Imaging},
