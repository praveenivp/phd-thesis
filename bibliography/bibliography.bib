@article{lawrenceLaminarFMRIApplications2019,
  title = {Laminar {{fMRI}}: {{Applications}} for Cognitive Neuroscience},
  author = {Lawrence, Samuel J.D. and Formisano, Elia and Muckli, Lars and family=Lange, given=Floris P., prefix=de, useprefix=true},
  date = {2019},
  journaltitle = {NeuroImage},
  volume = {197},
