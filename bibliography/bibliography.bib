@article{engelSingleshotSpiralImaging2018,
  title = {Single-Shot Spiral Imaging at 7 {{T}}},
  author = {Engel, Maria and Kasper, Lars and Barmet, Christoph and Schmid, Thomas and Vionnet, Laetitia and Wilm, Bertram and Pruessmann, Klaas P.},
  date = {2018},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {80},
