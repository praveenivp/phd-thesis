@article{barmetTransmitReceiveSystem2009,
  title = {A Transmit/Receive System for Magnetic Field Monitoring of in Vivo {{MRI}}},
  author = {Barmet, Christoph and De Zanche, Nicola and Wilm, Bertram J. and Pruessmann, Klaas P.},
  date = {2009},
