@article{zahneisenSimultaneousMultiSliceFMRI2014,
  title = {Simultaneous {{Multi-Slice fMRI}} Using Spiral Trajectories},
  author = {Zahneisen, Benjamin and Poser, Benedikt A. and Ernst, Thomas and Stenger, Andrew V.},
  date = {2014-05-15},
  journaltitle = {NeuroImage},
  shortjournal = {NeuroImage},
