@article{lustigSparseMRIApplication2007,
  title = {Sparse {{MRI}}: {{The}} Application of Compressed Sensing for Rapid {{MR}} Imaging},
  author = {Lustig, Michael and Donoho, David and Pauly, John M.},
  date = {2007},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {58},
  number = {6},
  pages = {1182--1195},
  issn = {07403194},
  doi = {10.1002/mrm.21391},
  abstract = {The sparsity which is implicit in MR images is exploited to significantly undersample k-space. Some MR images such as angiograms are already sparse in the pixel representation; other, more complicated images have a sparse representation in some transform domain-for example, in terms of spatial finite-differences or their wavelet coefficients. According to the recently developed mathematical theory of compressed-sensing, images with a sparse representation can be recovered from randomly undersampled k-space data, provided an appropriate nonlinear recovery scheme is used. Intuitively, artifacts due to random undersampling add as noise-like interference. In the sparse transform domain the significant coefficients stand out above the interference. A nonlinear thresholding scheme can recover the sparse coefficients, effectively recovering the image itself. In this article, practical incoherent undersampling schemes are developed and analyzed by means of their aliasing interference. Incoherence is introduced by pseudo-random variable-density undersampling of phase-encodes. The reconstruction is performed by minimizing the ℓ1 norm of a transformed image, subject to data fidelity constraints. Examples demonstrate improved spatial resolution and accelerated acquisition for multislice fast spin-echo brain imaging and 3D contrast enhanced angiography. © 2007 Wiley-Liss, Inc.},
  keywords = {Compressed sensing,Compressive sampling,Nonlinear reconstruction,Random sampling,Rapid MRI,Sparse reconstruction,Sparsity},
  file = {C:\Users\pvalsala\Zotero\storage\C8QW2ZEM\Lustig, Donoho, Pauly_2007_Sparse MRI The application of compressed sensing for rapid MR imaging.pdf}
}

@article{lustigSPIRiTIterativeSelfconsistent2010,
  title = {{{SPIRiT}}: {{Iterative}} Self-Consistent Parallel Imaging Reconstruction from Arbitrary k-Space},
  author = {Lustig, Michael and Pauly, John M.},
  date = {2010},
  journaltitle = {Magnetic Resonance in Medicine},
