@article{millerFunctionalBrainImaging2003,
  title = {Functional Brain Imaging Using a Blood Oxygenation Sensitive Steady State},
  author = {Miller, Karla L. and Hargreaves, Brian A. and Lee, Jongho and Ress, David and Christopher deCharms, R. and Pauly, John M.},
  date = {2003},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {50},
