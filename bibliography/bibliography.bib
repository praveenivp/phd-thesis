@thesis{patzigReconstructionStrategiesMRI2022,
  type = {Doctoral Thesis},
  title = {Reconstruction {{Strategies}} for {{MRI}} in {{Inhomogeneous Background Fields}}},
  author = {Patzig, Franz},
  date = {2022},
  institution = {ETH Zurich},
  doi = {10.3929/ethz-b-000556734},
  url = {https://www.research-collection.ethz.ch/handle/20.500.11850/556734},
  urldate = {2023-05-11},
  abstract = {Magnetic resonance imaging (MRI) is a highly versatile imaging modality with excellent soft-tissue contrast. Since it was first proposed in 1973, it has become a standard tool for diagnostics and research. The imaging process relies on a homogenous magnetic background field and time-varying gradient fields. However, the homogeneity of the background field is degraded when an object of irregular shape with a magnetic susceptibility different to that of air is brought into the scanner as the object interacts with the background field. Performing MRI under field inhomogeneities, which is therefore basically always the case and neglecting to address them in image reconstruction leads to artefacts in the acquired images and consequently a decreased image quality. In particular, methods reading the imaging data along long Fourier domain trajectories, i.e., so-called k-space trajectories, suffer from field inhomogeneities. However, these trajectories are particularly attractive as they allow for imaging at sub-millimeter resolution in a fraction of a second. The present thesis is dedicated to the investigation of correction algorithms adressing artefacts caused by field inhomogeneities. In the first part, image reconstruction and B0 inhomogeneity correction with known field inhomogeneities are studied. In the second part, B0 estimation via so-called implicit temporal encoding is proposed, permitting encoding of temporal information by the use of multi-coil arrays.},
  langid = {english},
  annotation = {Accepted: 2022-07-07T10:49:56Z},
  file = {C:\Users\pvalsala\Zotero\storage\CJ6SDU93\Patzig - 2022 - Reconstruction Strategies for MRI in Inhomogeneous.pdf}
}

