@article{irarrazabalFastThreeDimensional1995,
  title = {Fast {{Three Dimensional Magnetic Resonance Imaging}}},
  author = {Irarrazabal, Pablo and Nishimura, Dwight G.},
  date = {1995},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {33},
