  issn = {15222594},
  doi = {10.1002/mrm.27585},
  abstract = {Purpose: Relaxation and dephasing of water protons embedded in a vascular network is driven by local magnetic field inhomogeneities around deoxygenated blood vessels. These effects strongly depend on the relation between mean diffusion length and diameter of blood vessels, as well as on the chosen imaging sequence. In this work, the BOLD sensitivity of steady-state sequences as a function of vessel size, field strength, and sequence parameters are analyzed. Methods: Steady-state magnetization within a network of artificial cylinders is simulated with Monte Carlo methods for different coherence pathways. In addition, measurements on microspheres were performed to confirm theoretical results. Results: Simulations and phantom results demonstrate a vessel size-dependent signal attenuation effect of all coherence pathways. Both the FID and ECHO pathways show a signal profile similar to spin echo sequences where in the static dephasing regime the effect of larger vessels is suppressed. Conclusion: The BOLD effect measured in steady-state sequences is most sensitive to microvessels and might therefore be closer to the underlying neuronal event compared to gradient echo sequences. K E Y W O R D S blood oxygenation, diffusion, steady-state free precession, vessel size 1 | INTRODUCTION Most functional BOLD imaging experiments are acquired with gradient echo (GE) sequences in combination with an EPI readout. In some studies, spin echo (SE)-based EPI sequences have also been used 1-7 as these techniques are less sensitive to BOLD contributions from larger vessels. 8,9 As an alternative to GE and SE, balanced SSFP and S2-SSFP (F − 0 path or the non-balanced SSFP echo before the RF pulse) have been proposed and analyzed for BOLD imaging. 10-16 In a recent article, S1-SSFP (F + 0 path of the non-balanced SSFP echo after the RF pulse) has been introduced for BOLD imaging at 7T. 17 One major advantage of rapid SSFP sequences over EPI-based sequences is their lack of any spatial distortions along phase encode direction, which makes registration to anatomical images straight forward. This is especially important for sub millimeter resolution acquisitions that aim to disentangle signals from different cortical layers or columns. The BOLD sensitivity of different sequences to the underlying neurovascular vessel size is a further key feature to characterize the measured BOLD signal changes. The vessel size dependence of the BOLD effect is often divided into 2 regimes: the diffusion narrowing regime for small vessel sizes of up to \$\textbackslash sim\$5-10 μm diameter and the static dephasing regime for larger vessels. 8,9,18,19 In the static dephasing regime , dephasing effects around vessels are almost completely},
  keywords = {blood oxygenation,diffusion,steady-state free precession,vessel size},
  file = {C:\Users\pvalsala\Zotero\storage\ELUGPLXV\Scheffler et al._2019_The BOLD sensitivity of rapid steady-state sequences.pdf}
}

@article{schefflerDetectionBOLDChanges2001,
  title = {Detection of {{BOLD}} Changes by Means of a Frequency-Sensitive {{trueFISP}} Technique: {{Preliminary}} Results},
  author = {Scheffler, Klaus and Seifritz, Erich and Bilecen, Deniz and Venkatesan, Ramesh and Hennig, Jürgen and Deimling, Michael and Haacke, E. Mark},
