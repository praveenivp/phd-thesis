@article{wuTheoreticalExperimentalInvestigation2007,
  title = {A Theoretical and Experimental Investigation of the Tagging Efficiency of Pseudocontinuous Arterial Spin Labeling},
  author = {Wu, Wen Chau and Fernández-Seara, María and Detre, John A. and Wehrli, Felix W. and Wang, Jiongjiong},
