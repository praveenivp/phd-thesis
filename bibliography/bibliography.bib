@article{wangHighSNRRapid,
  title = {High {{SNR}} Rapid {{T1-weighted MPRAGE}} Using Spiral Imaging with Long Readouts and Improved Deblurring},
  author = {Wang, Dinghui and Robison, Ryan K. and Li, Zhiqiang and Pipe, James G.},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {n/a},
  number = {n/a},
  issn = {1522-2594},
  doi = {10.1002/mrm.29492},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/mrm.29492},
  urldate = {2022-11-23},
  abstract = {Purpose The goal of this work is to present the implementation of 3D spiral high-resolution MPRAGE and to demonstrate that SNR and scan efficiency increase with the increment of readout time. Theory Simplified signal equations for MPRAGE indicate that the T1 contrast can be kept approximately the same by a simple relationship between the flip angle and the TR. Furthermore, if T1 contrast remains the same, image SNR depends on the square root of the product of the total scan time and the readout time. Methods MPRAGE spiral sequences were implemented with distributed spirals and spiral staircase on 3 Tesla scanners. Brain images of three volunteers were acquired with different readout times. Spiral images were processed with a joint water–fat separation and deblurring algorithm and compared to Cartesian images. Pure noise data sets were also acquired for SNR evaluation. Results Consistent T1 weighting can be achieved with various spiral readout lengths, and between spiral MPRAGE imaging and the traditional Cartesian MPRAGE imaging. Noise performance analysis demonstrates higher SNR efficiency of spiral MPRAGE imaging with matched T1 contrast compared to the Cartesian reference imaging. Conclusion Fast, high SNR MPRAGE imaging is feasible with long readout spiral trajectories.},
  langid = {english},
  keywords = {deblurring,MPRAGE,SNR,spiral,T1 contrast,water–fat imaging},
  file = {C\:\\Users\\pvalsala\\Zotero\\storage\\ZTHH4JSN\\Wang et al. - High SNR rapid T1-weighted MPRAGE using spiral ima.pdf;C\:\\Users\\pvalsala\\Zotero\\storage\\6B4HRSB4\\mrm.html}
}

@article{wangJointWaterFat2018,
  title = {Joint Water–Fat Separation and Deblurring for Spiral Imaging},
  author = {Wang, Dinghui and Zwart, Nicholas R. and Pipe, James G.},
  date = {2018},
  journaltitle = {Magnetic Resonance in Medicine},
  volume = {79},
  number = {6},
  pages = {3218--3228},
  issn = {1522-2594},
  doi = {10.1002/mrm.26950},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/mrm.26950},
  urldate = {2023-11-23},
  abstract = {Purpose Most previous approaches to spiral Dixon water–fat imaging perform the water–fat separation and deblurring sequentially based on the assumption that the phase accumulation and blurring as a result of off-resonance are separable. This condition can easily be violated in regions where the B0 inhomogeneity varies rapidly. The goal of this work is to present a novel joint water–fat separation and deblurring method for spiral imaging. Methods The proposed approach is based on a more accurate signal model that takes into account the phase accumulation and blurring simultaneously. A conjugate gradient method is used in the image domain to reconstruct the deblurred water and fat iteratively. Spatially varying convolutions with a local convergence criterion are used to reduce the computational demand. Results Both simulation and high-resolution brain imaging have demonstrated that the proposed joint method consistently improves the quality of reconstructed water and fat images compared with the sequential approach, especially in regions where the field inhomogeneity changes rapidly in space. The loss of signal-to-noise-ratio as a result of deblurring is minor at optimal echo times. Conclusions High-quality water–fat spiral imaging can be achieved with the proposed joint approach, provided that an accurate field map of B0 inhomogeneity is available. Magn Reson Med 79:3218–3228, 2018. © 2017 International Society for Magnetic Resonance in Medicine.},
  langid = {english},
  keywords = {B0 correction,conjugate gradient,MRI,off-resonance correction,spiral deblurring,water–fat separation},
  file = {C\:\\Users\\pvalsala\\Zotero\\storage\\26L46ATM\\Wang et al. - 2018 - Joint water–fat separation and deblurring for spir.pdf;C\:\\Users\\pvalsala\\Zotero\\storage\\ZPYCRWHP\\mrm.html}
}

