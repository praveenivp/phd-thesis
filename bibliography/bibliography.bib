@article{zurSpoilingTransverseMagnetization1991a,
  title = {Spoiling of Transverse Magnetization in Steady-State Sequences},
  author = {Zur, Y. and Wood, M. L. and Neuringer, L. J.},
  date = {1991},
  journaltitle = {Magnetic Resonance in Medicine},
