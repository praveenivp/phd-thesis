@article{ongAcceleratingNonCartesianMRI2020,
  title = {Accelerating {{Non-Cartesian MRI Reconstruction Convergence Using}} k-{{Space Preconditioning}}},
  author = {Ong, Frank and Uecker, Martin and Lustig, Michael},
  date = {2020-05},
  journaltitle = {IEEE Transactions on Medical Imaging},
  volume = {39},
  number = {5},
  pages = {1646--1654},
  issn = {1558-254X},
  doi = {10.1109/TMI.2019.2954121},
  abstract = {We propose a k-space preconditioning formulation for accelerating the convergence of iterative Magnetic Resonance Imaging (MRI) reconstructions from non-uniformly sampled k-space data. Existing methods either use sampling density compensations which sacrifice reconstruction accuracy, or circulant preconditioners which increase per-iteration computation. Our approach overcomes both shortcomings. Concretely, we show that viewing the reconstruction problem in the dual formulation allows us to precondition in k-space using density-compensation-like operations. Using the primal-dual hybrid gradient method, the proposed preconditioning method does not have inner loops and are competitive in accelerating convergence compared to existing algorithms. We derive ℓ2-optimized preconditioners, and demonstrate through experiments that the proposed method converges in about ten iterations in practice.},
  eventtitle = {{{IEEE Transactions}} on {{Medical Imaging}}},
  keywords = {Acceleration,Convergence,density compensation,Gradient methods,Image reconstruction,iterative reconstruction,Magnetic resonance imaging,MRI,non-cartesian,preconditioner,preconditioning,Trajectory},
  file = {C\:\\Users\\pvalsala\\Zotero\\storage\\K4N6GT5Y\\Ong et al. - 2020 - Accelerating Non-Cartesian MRI Reconstruction Conv.pdf;C\:\\Users\\pvalsala\\Zotero\\storage\\UI8NVB2Y\\8906069.html}
}

